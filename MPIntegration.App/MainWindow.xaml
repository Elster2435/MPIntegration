<Window x:Class="MPIntegration.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MPIntegration.App"
        mc:Ignorable="d"
        Title="MainWindow" Height="500" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Button Width="100"
                    Height="35"
                    Margin="0,0,10,0"
                    Content="Добавить треки"
                    Command="{Binding AddTracksCommand}"/>
            <Button Width="100"
                    Height="35"
                    Margin="0,0,10,0"
                    Content="Удалить трек"
                    Command="{Binding DeleteTrackCommand}"/>
            <Button Width="100"
                    Height="35"
                    Content="Открыть папку"
                    Command="{Binding OpenTracksFolderCommand}"/>
        </StackPanel>
        <TextBlock Grid.Row="2"
                   x:Name="CurrentTrackTextBlock"
                   FontSize="14"
                   FontWeight="Bold"
                   Text="{Binding CurrentTrackText}"/>
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Text="Поиск:"/>
            <TextBox Grid.Column="2"
                     x:Name="SearchTextBox"
                     Height="28"
                     VerticalContentAlignment="Center"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Width="100"
                    Height="35"
                    Margin="0,0,10,0"
                    Content="Prev"
                    Command="{Binding PrevCommand}"/>
            <Button Width="100"
                    Height="35"
                    Margin="0,0,10,0"
                    Content="Play"
                    Command="{Binding PlayCommand}"/>
            <Button Width="100"
                    Height="35"
                    Margin="0,0,10,0"
                    Content="Pause"
                    Command="{Binding PauseCommand}"/>
            <Button Width="100"
                    Height="35"
                    Margin="0,0,10,0"
                    Content="Stop"
                    Command="{Binding StopCommand}"/>
            <Button Width="100"
                    Height="35"
                    Content="Next"
                    Command="{Binding NextCommand}"/>
        </StackPanel>
        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Text="{Binding CurrentTimeText}"/>
            <Slider Grid.Column="1"
                    x:Name="TrackPositionSlider"
                    Minimum="0"
                    Maximum="{Binding TrackMaximum}"
                    Value="{Binding TrackPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Grid.Column="2"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"
                       Text="{Binding TotalTimeText}"/>
            <TextBlock Grid.Column="4"
                       VerticalAlignment="Center"
                       Text="Громкость:"/>
            <Slider Grid.Column="5"
                    x:Name="VolumeSlider"
                    Minimum="0"
                    Maximum="100"
                    Value="{Binding Volume, Mode=TwoWay}"/>
        </Grid>
        <ListBox Grid.Row="10"
                 x:Name="TracksListBox"
                 ItemsSource="{Binding Tracks}"
                 SelectedItem="{Binding SelectedTrack, Mode=TwoWay}"
                 MouseDoubleClick="TracksListBox_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="5" Margin="2" BorderBrush="#DDD" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{Binding Title}" 
                                       FontWeight="Bold"
                                       FontSize="14"/>
                            <TextBlock Text="{Binding Artist}" 
                                       Foreground="Gray"/>
                            <TextBlock Text="{Binding DisplayPath}" 
                                       FontSize="10"
                                       Foreground="DarkGray"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
